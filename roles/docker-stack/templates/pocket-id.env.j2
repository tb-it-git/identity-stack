# Pocket ID Konfiguration
APP_URL={{ pocket_id_app_url }}
TRUST_PROXY=true
ENCRYPTION_KEY={{ pocket_id_encryption_key }}

# SMTP
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_FROM={{ smtp_from }}
SMTP_USER={{ smtp_user }}
SMTP_PASSWORD={{ smtp_password }}
SMTP_TLS={{ smtp_tls }}
SMTP_SKIP_CERT_VERIFY=true

# Mail-Features
EMAIL_LOGIN_NOTIFICATION_ENABLED=true
EMAIL_VERIFICATION_ENABLED=true
EMAIL_ONE_TIME_ACCESS_AS_ADMIN_ENABLED=true

# LDAP-Anbindung an LLDAP
LDAP_ENABLED=false
LDAP_URL=ldap://lldap:3890
LDAP_BIND_DN=uid=svc-pocketid,ou=people,{{ lldap_base_dn }}
LDAP_BIND_PASSWORD={{ lldap_bind_password }}
LDAP_BASE_DN=ou=people,{{ lldap_base_dn }}
LDAP_ADMIN_GROUP_NAME=lldap_admin

# UI-Config: false = Konfiguration ueber Web-UI moeglich (empfohlen fuer Setup)
# Fuer Produktion auf true setzen, damit nur Env-Variablen gelten
UI_CONFIG_DISABLED=false
